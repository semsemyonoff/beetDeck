# Copy to .env and adjust. Consumed by docker-compose.yml.

# Published image + tag to run. Pin to a release (e.g. 1.0.0) in production;
# `latest` is fine for trying it out.
BEETDECK_IMAGE=semsemyonoff/beetdeck
BEETDECK_TAG=latest

# Host port the UI/API is exposed on (container always serves on 5000).
BEETDECK_HTTP_PORT=8080

# Host paths bind-mounted into the container.
#   config/ — your beets config.yaml (BEETSDIR)
#   music/  — your audio library / import dir
BEETDECK_CONFIG_DIR=./config
BEETDECK_MUSIC_DIR=./music

# Container timezone (affects logs / timestamps).
TZ=UTC
